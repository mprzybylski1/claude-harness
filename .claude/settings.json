{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun devicectl *)",
      "Bash(python scripts/tools/generate_ticket_index.py *)",
      "Bash(python scripts/tools/extract_opus_key_sections.py *)",
      "Bash(python scripts/tools/extract_session_brief.py *)",
      "Bash(python scripts/tools/surface_stale_tickets.py *)",
      "Bash(python scripts/tools/repo_hygiene.py *)",
      "Bash(python scripts/tools/workspace.py *)",
      "Bash(python scripts/tools/workspace_internal_path.py *)",
      "Bash(python scripts/tools/current_session.py *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/check_ticket_acs.py\"'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/check_cross_layer_writes.py\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/check_fix_commit_has_code.py\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/regenerate_ticket_index.py\"'"
          },
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/check_skill_bash_blocks_hook.py\"'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/log_tool_usage.py\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'python3 \"$(git rev-parse --show-toplevel)/scripts/hooks/check_session_log.py\"'"
          }
        ]
      }
    ]
  }
}
