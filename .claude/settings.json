{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git -C *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun devicectl *)",
      "Bash(xcrun simctl *)",
      "Bash(echo -n *)",
      "Bash(python -m pytest *)",
      "Bash(python scripts/tools/archive_session_log.py *)",
      "Bash(python scripts/tools/classify_session.py *)",
      "Bash(python scripts/tools/close_ticket.py *)",
      "Bash(python scripts/tools/create_ticket.py *)",
      "Bash(python scripts/tools/current_session.py *)",
      "Bash(python scripts/tools/extract_opus_key_sections.py *)",
      "Bash(python scripts/tools/extract_session_brief.py *)",
      "Bash(python scripts/tools/generate_ticket_index.py *)",
      "Bash(python scripts/tools/list_raised_concerns.py *)",
      "Bash(python scripts/tools/portfolio.py *)",
      "Bash(python scripts/tools/prepare_opus_context.py *)",
      "Bash(python scripts/tools/promote_raised_concern.py *)",
      "Bash(python scripts/tools/repo_hygiene.py *)",
      "Bash(python scripts/tools/rotate_opus_notes.py *)",
      "Bash(python scripts/tools/session_close_commit_msg.py *)",
      "Bash(python scripts/tools/surface_stale_tickets.py *)",
      "Bash(python scripts/tools/surface_workspace_concerns.py *)",
      "Bash(python scripts/tools/update_system_state.py *)",
      "Bash(python scripts/tools/workspace.py *)",
      "Bash(python scripts/tools/workspace_internal_path.py *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" check_ticket_acs || exit 0'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" check_cross_layer_writes || exit 0'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" check_fix_commit_has_code || exit 0'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" regenerate_ticket_index || exit 0'"
          },
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" check_skill_bash_blocks_hook || exit 0'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" log_tool_usage || exit 0'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'H=\"$CLAUDE_PROJECT_DIR/scripts/hooks/run_hook.sh\"; [ -f \"$H\" ] && exec bash \"$H\" check_session_log || exit 0'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true
  }
}
